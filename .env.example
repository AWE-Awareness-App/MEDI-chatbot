# ============================================================
# MEDI Chatbot - Environment Variables
# Copy this file to .env and fill in all values.
# In Azure, set these under:
#   Web App -> Settings -> Environment variables
# ============================================================

# --- App ---
APP_NAME=MEDI
ENV=production
LOG_LEVEL=INFO

# --- Database (Azure PostgreSQL Flexible Server with pgvector) ---
# Format: postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=

# --- OpenAI (Embeddings) ---
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Anthropic (LLM) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
LLM_PROVIDER=anthropic
USE_LLM=true
LLM_MAX_HISTORY=12

# --- Twilio (WhatsApp) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
MENU_TEMPLATE_SID=

# --- RAG ---
RAG_TOP_K=5
DEBUG_RAG=false

# --- Azure Neural TTS (fallback to Chatterbox when key missing) ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_TTS_VOICE=en-US-JennyNeural
AZURE_TTS_STYLE=
AZURE_TTS_RATE=0%
AZURE_TTS_PITCH=0%
CHATTERBOX_DEVICE=cpu
CHATTERBOX_EXAGGERATION=0.3
CHATTERBOX_CFG_WEIGHT=0.3
CHATTERBOX_TEMPERATURE=0.3

# --- Azure Blob (all audio storage) ---
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=medi-audio
AZURE_BLOB_URL_TTL_SECONDS=86400

# --- Azure Container Port ---
# Must match the port uvicorn listens on (8000)
WEBSITES_PORT=8000

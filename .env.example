# ============================================================
# MEDI Chatbot — Environment Variables
# Copy this file to .env and fill in all values.
# In Azure, set these under:
#   Web App -> Settings -> Environment variables
# ============================================================

# --- App ---
APP_NAME=MEDI
ENV=production
LOG_LEVEL=INFO

# --- Database (Azure PostgreSQL Flexible Server with pgvector) ---
# Format: postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=

# --- OpenAI (Embeddings) ---
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Anthropic (LLM) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
LLM_PROVIDER=anthropic
USE_LLM=true
LLM_MAX_HISTORY=12

# --- Twilio (WhatsApp) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
MENU_TEMPLATE_SID=
PUBLIC_BASE_URL=

# --- RAG ---
RAG_TOP_K=5
DEBUG_RAG=false

# --- Voice/TTS ---
LOCAL_AUDIO_STORAGE_DIR=/app/.local_audio
PIPER_MODEL_PATH=/app/.local_audio/piper_models/en_US-hfc_female-medium.onnx
USE_LOCAL_AUDIO_STORAGE=false
AZURE_STORAGE_CONNECTION_STRING=
# Blob container is fixed in code: medi-audio

# --- Azure Container Port ---
# Must match the port uvicorn listens on (8000)
WEBSITES_PORT=8000
